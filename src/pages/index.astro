                  </article>
                  <article>
                    <small>JÁ CONSULTARAM</small>
                    <strong id="kpi-patients" class="kpi-green">131</strong>
                    <span>92,3% DO TOTAL</span>
                    <em>Casos em etapa pós-consulta</em>
                  </article>
                  <article>
                    <small>TRATAMENTO INICIADO</small>
                    <strong id="kpi-guides" class="kpi-green">89</strong>
                    <span>62,7% DO TOTAL</span>
                    <em>Conversões efetivas</em>
                  </article>
                </div>

                <!-- Distribuição pós-consulta — 5 colunas com dados fictícios -->
                <div class="crm-section-hd">
                  <span>DISTRIBUIÇÃO PÓS-CONSULTA</span>
                  <span>Onde estão os pacientes que já passaram pela consulta</span>
                </div>
                <div class="crm-dist5">
                  <article>
                    <small>INVESTIGAÇÃO/AVALIAÇÃO</small>
                    <strong class="kpi-orange">14</strong>
                    <span>10,7% dos que consultaram</span>
                    <em>Aguardam definição clínica</em>
                  </article>
                  <article>
                    <small>CONDUTA PENDENTE</small>
                    <strong class="kpi-orange">9</strong>
                    <span>6,9% dos que consultaram</span>
                    <em>Consulta realizada; falta desfecho</em>
                  </article>
                  <article>
                    <small>ACOMPANHAMENTO</small>
                    <strong>31</strong>
                    <span>23,7% dos que consultaram</span>
                    <em>Seguimento ativo</em>
                  </article>
                  <article>
                    <small>ENCAMINHADOS</small>
