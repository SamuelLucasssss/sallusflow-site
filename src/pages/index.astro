                </div>

                <!-- Resumo da jornada — 4 KPIs com dados fictícios -->
                <div class="crm-section-hd">
                  <span>RESUMO DA JORNADA</span>
                  <span>Consulta como marco principal do funil</span>
                </div>
                <div class="crm-kpi4">
                  <article>
                    <small>TOTAL CRM</small>
