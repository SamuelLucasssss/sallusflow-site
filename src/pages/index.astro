                    <small>§ 02.02 · MESA OPERACIONAL</small>
                    <div class="crm-totals">
                      <span>TOTAL <b>142</b></span>
                      <span>JÁ CONSULTARAM <b>131</b></span>
                      <span>TRATAMENTO <b>89</b></span>
