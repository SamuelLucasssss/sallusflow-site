---
import Layout from '../layouts/Layout.astro';
import NavIsland from '../components/NavIsland';
import ModuleTabs from '../components/ModuleTabs';
import FaqAccordion from '../components/FaqAccordion';
import '../styles.css';

const whatsappMessage = encodeURIComponent('Olá! Quero conhecer o Sallus Flow e entender como aplicar na gestão oncológica.');
const whatsappUrl = `https://wa.me/5562992499048?text=${whatsappMessage}`;
const systemUrl = 'https://oncologia.sallusflow.com.br';

const flowSteps = ['Indicação', 'Consulta', 'Paciente', 'Guia', 'Produção', 'Faturamento', 'Glosa/Recurso', 'Recebimento'];

const decisionLoop = [
  { title: 'Sinal',       text: 'O sistema identifica pendência, atraso, guia em risco ou gargalo operacional.' },
  { title: 'Diagnóstico', text: 'A gestão entende o motivo: origem, etapa, responsável e impacto provável.' },
  { title: 'Ação',        text: 'A equipe sabe o que precisa ser feito primeiro, sem caçar informação em cinco lugares.' },
  { title: 'Evidência',   text: 'O histórico fica organizado para auditoria, aprendizado e melhoria contínua.' },
];

const audiences = [
  'Clínicas oncológicas', 'Ambulatórios hospitalares', 'Gestores de saúde',
  'Faturamento e auditoria', 'Coordenação assistencial', 'Diretoria executiva',
];

const implementationSteps = [
  { num: '01', title: 'Mapear fluxo real',   text: 'Entender como a indicação nasce, como vira consulta, onde a guia trava e onde a receita se perde.' },
  { num: '02', title: 'Organizar base',       text: 'Padronizar campos, status, responsáveis, convênios e pontos críticos antes de automatizar qualquer coisa.' },
  { num: '03', title: 'Ativar rotina',        text: 'Treinar equipe, definir donos por etapa e transformar o painel em ritual semanal de decisão.' },
  { num: '04', title: 'Evoluir por evidência',text: 'Ajustar indicadores, alertas e módulos conforme a operação amadurece. Sem chute. Com rastro.' },
];

const governanceItems = [
  { label: 'LGPD — Lei 13.709/2018',                text: 'Dados tratados conforme a Lei Geral de Proteção de Dados. Finalidade, consentimento e segurança como princípios inegociáveis de operação.' },
  { label: 'Infraestrutura nacional',               text: 'Dados hospedados em nuvem com servidores em território brasileiro. Sem transferência internacional de dados sensíveis de saúde.' },
  { label: 'Acesso por perfil com log de auditoria',text: 'Cada ação registrada com usuário, timestamp e contexto. Trilha de auditoria disponível para gestão e compliance interno.' },
  { label: 'Demonstrações com dados fictícios',     text: 'Nenhuma informação real de paciente em ambientes públicos ou de demonstração. Dado sensível de saúde não é peça de vitrine.' },
];

const delay = (i: number) => i > 0 ? ` delay-${Math.min(i, 4)}` : '';
const year  = new Date().getFullYear();
---

<Layout>
  <div class="site-shell">

    <!-- NAV -->
    <header class="header">
      <a class="brand" href="#top" aria-label="Sallus Flow">
        <span class="brand-mark"><i></i></span>
        <strong>Sallus<span>Flow</span></strong>
      </a>
      <!-- Hamburger + nav: React island (interatividade mínima) -->
      <NavIsland client:load />
    </header>

    <main>

      <!-- HERO -->
      <section id="top" class="hero section-grid">
        <div class="hero-copy reveal">
          <p class="eyebrow">SALLUS FLOW · INTELIGÊNCIA OPERACIONAL EM ONCOLOGIA</p>
          <h1>Sua operação oncológica perde mais do que você consegue ver.</h1>
          <p class="lead">Sallus Flow conecta CRM, pacientes, guias e faturamento em um comando único — para que a equipe saiba onde agir antes que o prejuízo aconteça.</p>
          <div class="hero-actions">
            <a class="button primary" href={whatsappUrl} target="_blank" rel="noreferrer">Solicitar demonstração</a>
            <a class="button secondary" href={systemUrl} target="_blank" rel="noreferrer">Entrar no sistema</a>
          </div>
          <div class="trust-row" aria-label="Diferenciais principais">
            <span><b>01</b> fluxo único</span>
            <span><b>05</b> módulos conectados</span>
            <span><b>100%</b> foco operacional</span>
          </div>
        </div>

        <div class="product-stage reveal delay-1" aria-label="Prévia visual do painel Sallus Flow">
          <div class="screen-glow"></div>
          <div class="browser-frame">
            <div class="browser-top">
              <span></span><span></span><span></span>
              <strong>oncologia.sallusflow.com.br</strong>
            </div>
            <div class="command-panel">

              <!-- Sidebar fiel ao sistema real -->
              <aside class="crm-sidebar">
                <div class="crm-brand">
                  <span class="crm-brand-dot"></span>
                  <span>Sallus <em>Oncologia</em></span>
                </div>
                <div class="crm-nav-section">
                  <p class="crm-nav-label">MÓDULOS</p>
                  <span class="crm-nav-item">M0 · Executivo</span>
                  <span class="crm-nav-item active">M1 · CRM</span>
                  <span class="crm-nav-item">M2 · Pacientes</span>
                  <span class="crm-nav-item">M3 · Financeiro</span>
                  <span class="crm-nav-item">M4 · Guias</span>
                </div>
                <div class="crm-nav-section">
                  <p class="crm-nav-label">§ CRM</p>
                  <span class="crm-nav-item sub active">Funil</span>
                  <span class="crm-nav-item sub">Médicos indicadores</span>
                  <span class="crm-nav-item sub">Revisão</span>
                  <span class="crm-nav-item sub">Importar planilha</span>
                </div>
              </aside>

              <!-- Painel principal — dados fictícios de demonstração -->
              <div class="crm-main">

                <!-- Topbar: breadcrumb + status badges -->
                <div class="crm-topbar">
                  <div class="crm-breadcrumb">
                    <span>M1</span>
                    <span class="crm-sep">/</span>
                    <span>CRM</span>
                    <span class="crm-sep">/</span>
                    <strong>Pipeline de indicações</strong>
                  </div>
                  <div class="crm-badges">
                    <span>ONCOLOGIA</span>
                    <span>SUPABASE</span>
                    <span>PRODUÇÃO</span>
                    <span class="badge-live"><i></i>AO VIVO</span>
                  </div>
                </div>

                <!-- Banner de ação -->
                <div class="crm-action-bar">
                  <div>
                    <strong>NOVA INDICAÇÃO</strong>
                    <small>Cadastro guiado: paciente, contato, clínico, indicador, convênio e operação</small>
                  </div>
                  <span class="crm-cta">+ Cadastrar indicação</span>
                </div>

                <!-- Cabeçalho da página -->
