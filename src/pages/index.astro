          </div>
          <div class="about-contact reveal delay-1">
            <p>Quer conhecer quem está por trás do Sallus Flow?</p>
            <a class="button primary" href={whatsappUrl} target="_blank" rel="noreferrer">Falar com o time</a>
            <a class="about-email" href="mailto:contato@sallusflow.com.br">contato@sallusflow.com.br</a>
          </div>
        </div>
      </section>

      <!-- FAQ (React island) -->
      <section class="section faq-section">
        <div class="section-title reveal">
          <p class="eyebrow">09 · PERGUNTAS IMPORTANTES</p>
          <h2>Sem promessa solta. Sem fumaça de palco.</h2>
        </div>
        <FaqAccordion client:visible />
      </section>

      <!-- CTA FINAL -->
      <section id="contato" class="final-cta reveal">
        <p class="eyebrow">PRÓXIMO PASSO</p>
        <h2>Pare de administrar oncologia no escuro.</h2>
        <p>Leve a operação para um ambiente onde indicação, paciente, guia, faturamento e decisão conversam entre si.</p>
        <div class="hero-actions center-actions" style="margin-top: 32px;">
          <a class="button primary" href={whatsappUrl} target="_blank" rel="noreferrer">Falar no WhatsApp</a>
          <a class="button dark-button" href="mailto:contato@sallusflow.com.br">contato@sallusflow.com.br</a>
        </div>
        <small>Sistema: oncologia.sallusflow.com.br · WhatsApp: 62 9 9249-9048</small>
      </section>

    </main>

    <footer>© {year} Sallus Flow · www.sallusflow.com.br</footer>

  </div><!-- /site-shell -->
</Layout>

<script>
  // ── Scroll reveal ─────────────────────────────────────────────
  const revealObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add('visible');
          revealObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
  );
  document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => revealObs.observe(el));

  // ── Nav blur on scroll ────────────────────────────────────────
  const header = document.querySelector('.header');
  window.addEventListener('scroll', () => {
    header?.classList.toggle('nav-scrolled', window.scrollY > 30);
  }, { passive: true });

  // ── KPI counter ───────────────────────────────────────────────
  function countUp(el: HTMLElement, target: number, pad?: number) {
    const obs = new IntersectionObserver(([entry]) => {
      if (!entry.isIntersecting) return;
      obs.unobserve(el);
      let t0: number | null = null;
      const dur = 1300;
      const tick = (ts: number) => {
        if (!t0) t0 = ts;
        const p = Math.min((ts - t0) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const val = Math.round(eased * target);
        el.textContent = pad ? String(val).padStart(pad, '0') : String(val);
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }, { threshold: 0.6 });
    obs.observe(el);
  }

  const kpiCrm      = document.getElementById('kpi-crm');
  const kpiPatients = document.getElementById('kpi-patients');
  const kpiGuides   = document.getElementById('kpi-guides');
  if (kpiCrm)      countUp(kpiCrm, 142);
  if (kpiPatients) countUp(kpiPatients, 131);
  if (kpiGuides)   countUp(kpiGuides, 89);

  // ── Spotlight cursor glow ─────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.spotlight-card').forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const r = card.getBoundingClientRect();
      const x = e.clientX - r.left;
      const y = e.clientY - r.top;
      card.style.background =
        `radial-gradient(280px at ${x}px ${y}px, rgba(221,86,14,.09), transparent 70%), var(--card)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.background = '';
    });
  });
</script>
